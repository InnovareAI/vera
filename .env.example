# ⚠️ Only VITE_*-prefixed vars ship into the browser bundle. NEVER put an
# LLM, image-gen, publishing, or third-party API key here — those all live
# on Hetzner at /srv/supabase-content/.env and only edge functions touch
# them. The frontend calls edge functions (which hold the keys) instead of
# calling third-party APIs directly.

# Supabase — self-hosted on Hetzner (content stack). The anon key is
# designed to ship to browsers; it's RLS-gated.
VITE_SUPABASE_URL=https://supabase-content-eu.innovareai.com
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Sentry — optional. When set, the frontend ships render crashes (caught by
# the ErrorBoundary) and uncaught exceptions to Sentry. When absent the SDK
# is dead-code-eliminated from the production bundle — no runtime cost.
# Get the DSN from the Sentry project settings.
VITE_SENTRY_DSN=

# Optional release identifier (commit SHA, version tag, …) attached to
# Sentry events so a crash can be traced back to a specific deploy.
VITE_RELEASE=

# Optional browser hint. Keep false unless the production Edge Function
# environment also has PLATFORM_MEDIA_KEYS_ENABLED=true.
VITE_PLATFORM_MEDIA_KEYS_ENABLED=false

# Server-side only. Used by the extract-business-context Edge Function for
# Innovare-owned source scraping. Do not expose this as a VITE_* variable.
INNOVARE_APIFY_TOKEN=

# Server-side only. Used by google-oauth-start and google-oauth-callback for
# Google Search Console plus GA4 authorization. Configure the redirect URI in
# Google Cloud as:
# https://supabase-content-eu.innovareai.com/functions/v1/google-oauth-callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_STATE_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://supabase-content-eu.innovareai.com/functions/v1/google-oauth-callback

# Server-side only. Used by meta-oauth-start and meta-oauth-callback for
# Facebook Pages plus Instagram Professional authorization. Configure the
# Valid OAuth Redirect URI in Meta as:
# https://supabase-content-eu.innovareai.com/functions/v1/meta-oauth-callback
META_OAUTH_CLIENT_ID=
META_OAUTH_CLIENT_SECRET=
META_BUSINESS_LOGIN_CONFIG_ID=
META_OAUTH_STATE_SECRET=
META_OAUTH_REDIRECT_URI=https://supabase-content-eu.innovareai.com/functions/v1/meta-oauth-callback
META_GRAPH_API_VERSION=v25.0

VERA_ALLOWED_RETURN_ORIGINS=https://vera.innovareai.com,http://localhost:5173,http://127.0.0.1:5173

# Server-side only. When false or unset, InnovareAI-owned media provider keys
# cannot be used for image or video generation. Client BYOK media keys still
# work. Turn on only for approved internal media projects plus operator
# entitlements.
PLATFORM_MEDIA_KEYS_ENABLED=false
