# Supabase — self-hosted on Hetzner (content stack). Keys live on the server at /srv/supabase-content/.env
VITE_SUPABASE_URL=https://supabase-content-eu.innovareai.com
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OpenRouter — get from openrouter.ai/keys (covers GPT, Gemini, Mistral, DeepSeek, Qwen…)
VITE_OPENROUTER_API_KEY=your_openrouter_key_here

# Anthropic — Claude SDK direct (Brand Guard + core pipeline)
VITE_ANTHROPIC_API_KEY=your_anthropic_key_here

# Airtable — catalog export only (optional)
# VITE_AIRTABLE_API_KEY=your_airtable_personal_access_token_here
