# ⚠️ Only VITE_*-prefixed vars ship into the browser bundle. NEVER put an
# LLM, image-gen, publishing, or third-party API key here — those all live
# on Hetzner at /srv/supabase-content/.env and only edge functions touch
# them. The frontend calls edge functions (which hold the keys) instead of
# calling third-party APIs directly.

# Supabase — self-hosted on Hetzner (content stack). The anon key is
# designed to ship to browsers; it's RLS-gated.
VITE_SUPABASE_URL=https://supabase-content-eu.innovareai.com
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Sentry — optional. When set, the frontend ships render crashes (caught by
# the ErrorBoundary) and uncaught exceptions to Sentry. When absent the SDK
# is dead-code-eliminated from the production bundle — no runtime cost.
# Get the DSN from the Sentry project settings.
VITE_SENTRY_DSN=

# Optional release identifier (commit SHA, version tag, …) attached to
# Sentry events so a crash can be traced back to a specific deploy.
VITE_RELEASE=
